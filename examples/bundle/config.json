{
  "ociVersion": "1.0.2-dev",
  "hostname": "oci-demo",
  "process": {
    "terminal": false,
    "user": { "uid": 0, "gid": 0 },
    "args": ["/bin/sh", "/init.sh"],
    "env": [
      "PATH=/bin:/sbin:/usr/bin:/usr/sbin",
      "TERM=linux",
      "container=krunc",
      "KRUNC_PIDS_TEST=1"
    ],
    "cwd": "/",
    "noNewPrivileges": true,
    "capabilities": {
      "bounding": [
        "CAP_CHOWN", "CAP_KILL", "CAP_SETGID", "CAP_SETUID",
        "CAP_NET_BIND_SERVICE", "CAP_AUDIT_WRITE"
      ]
    },
    "oomScoreAdj": -500,
    "rlimits": [
      { "type": "RLIMIT_NOFILE", "soft": 256, "hard": 512 },
      { "type": "RLIMIT_CORE", "soft": 0, "hard": 0 }
    ]
  },
  "root": { "path": "rootfs", "readonly": false },
  "linux": {
    "namespaces": [
      { "type": "pid" },
      { "type": "mount" },
      { "type": "uts" },
      { "type": "ipc" },
      { "type": "network" }
    ],
    "cgroupsPath": "krunc/oci1",
    "resources": { "pids": { "limit": 16 } },
    "maskedPaths": ["/proc/kcore", "/proc/sysrq-trigger"],
    "readonlyPaths": ["/proc/sys", "/etc"],
    "seccomp": {
      "defaultAction": "SCMP_ACT_ALLOW",
      "architectures": ["SCMP_ARCH_X86_64"],
      "syscalls": [
        {
          "names": ["chmod", "fchmod", "fchmodat"],
          "action": "SCMP_ACT_ERRNO",
          "errnoRet": 1
        },
        {
          "names": [
            "ptrace", "keyctl", "add_key", "request_key", "bpf",
            "userfaultfd", "perf_event_open", "kexec_load",
            "init_module", "finit_module", "setns"
          ],
          "action": "SCMP_ACT_ERRNO",
          "errnoRet": 1
        }
      ]
    }
  }
}
