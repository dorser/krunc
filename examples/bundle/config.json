{
  "ociVersion": "1.0.2-dev",
  "hostname": "oci-demo",
  "process": {
    "terminal": false,
    "user": { "uid": 0, "gid": 0 },
    "args": ["/bin/sh", "/init.sh"],
    "env": [
      "PATH=/bin:/sbin:/usr/bin:/usr/sbin",
      "TERM=linux",
      "container=krunc"
    ],
    "cwd": "/",
    "noNewPrivileges": true,
    "capabilities": {
      "bounding": [
        "CAP_CHOWN", "CAP_KILL", "CAP_SETGID", "CAP_SETUID",
        "CAP_NET_BIND_SERVICE", "CAP_AUDIT_WRITE"
      ]
    }
  },
  "root": { "path": "rootfs", "readonly": false },
  "linux": {
    "namespaces": [
      { "type": "pid" },
      { "type": "mount" },
      { "type": "uts" },
      { "type": "ipc" },
      { "type": "network" }
    ]
  }
}
